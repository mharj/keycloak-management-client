{
  "name": "keycloak-management-client",
  "version": "0.1.0",
  "description": "Keycloak Management API client",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    "import": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "require": {
      "types": "./dist/index.d.cts",
      "default": "./dist/index.cjs"
    },
    "default": "./dist/index.mjs"
  },
  "scripts": {
    "build": "tsdown src/index.ts --format cjs,esm --dts --clean",
    "prepublishOnly": "npm run build",
    "test": "vitest test --run --no-isolate --coverage",
    "coverage": "vitest test --run --no-isolate --reporter=dot --coverage --coverage.reporter=lcov",
    "lint": "biome check",
    "validate": "tsc --noEmit --project tsconfig.test.json"
  },
  "files": [
    "dist"
  ],
  "mocha": {
    "exit": true,
    "extension": [
      "ts",
      "js"
    ],
    "recursive": true,
    "require": [
      "ts-node/register",
      "source-map-support/register"
    ],
    "file": [
      "test/mocha.env.ts"
    ],
    "reporters": [
      "spec",
      "mocha-junit-reporter"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mharj/keycloak-management-client.git"
  },
  "keywords": [
    "keycloak",
    "management"
  ],
  "author": "mharj",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mharj/keycloak-management-client/issues"
  },
  "homepage": "https://github.com/mharj/keycloak-management-client#readme",
  "devDependencies": {
    "@avanio/logger-like": "^0.2.12",
    "@biomejs/biome": "^2.5.0",
    "@luolapeikko/result-option": "^2.2.3",
    "@luolapeikko/ts-common": "^1.1.6",
    "@types/node": "^24.13.2",
    "@vitest/coverage-v8": "^4.1.9",
    "c8": "^11.0.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "jwt-decode": "^4.0.0",
    "tachyon-drive": "^2.0.0",
    "tachyon-drive-node-fs": "^2.0.0",
    "tsdown": "^0.22.2",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "zlib": "^1.0.5",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@avanio/logger-like": ">= 0.2.0",
    "@luolapeikko/result-option": ">= 1.0.0",
    "@luolapeikko/ts-common": ">= 1.0.0",
    "jwt-decode": ">= 4.0.0",
    "zod": ">= 4.0.0"
  },
  "packageManager": "pnpm@10.34.3+sha512.f2c531b08829d7be7f03c90addc266615f9c5477463e4bf1d275cb263ce9ea57cf0d5599110d94649a9bb3fed9f0b5efcea74a7016b61532a24cb9ad87860c1d"
}
